    "22": {
      "name": "Claris FileMaker 2024",
      "releaseYear": 2024,
      "internalVersion": "22.x",
      "status": "supported",
      "features": {
        "serviceDocument": true,
        "metadata": true,
        "databaseListing": true,
        "tableListing": true,
        "recordCRUD": true,
        "recordReferences": true,
